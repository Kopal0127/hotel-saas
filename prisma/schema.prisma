generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://postgres:Mottu%40123@localhost:5432/hoteldb?schema=public"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(HOTEL_OWNER)
  createdAt DateTime @default(now())
  hotels    Hotel[]
}

model Hotel {
  id          String       @id @default(cuid())
  name        String
  address     String?
  phone       String?
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  rooms       Room[]
  createdAt   DateTime     @default(now())
  channels    OtaChannel[]
  otaBookings OtaBooking[]
}

model Room {
  id          String       @id @default(cuid())
  number      String
  type        String
  price       Float
  hotelId     String
  hotel       Hotel        @relation(fields: [hotelId], references: [id])
  bookings    Booking[]
  ratePlans   RatePlan[]
  otaBookings OtaBooking[]
}

model Booking {
  id         String        @id @default(cuid())
  roomId     String
  room       Room          @relation(fields: [roomId], references: [id])
  guestName  String
  guestEmail String
  checkIn    DateTime
  checkOut   DateTime
  status     BookingStatus @default(PENDING)
  amount     Float
  createdAt  DateTime      @default(now())
}

model OtaChannel {
  id          String     @id @default(cuid())
  hotelId     String
  hotel       Hotel      @relation(fields: [hotelId], references: [id])
  name        OtaName
  isConnected Boolean    @default(false)
  apiKey      String?
  apiSecret   String?
  propertyId  String?
  lastSyncAt  DateTime?
  createdAt   DateTime   @default(now())
  syncLogs    SyncLog[]
  ratePlans   RatePlan[]

  @@unique([hotelId, name])
}

model RatePlan {
  id        String     @id @default(cuid())
  channelId String
  channel   OtaChannel @relation(fields: [channelId], references: [id])
  roomId    String
  room      Room       @relation(fields: [roomId], references: [id])
  date      DateTime
  price     Float
  available Int
  isBlocked Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model SyncLog {
  id        String     @id @default(cuid())
  channelId String
  channel   OtaChannel @relation(fields: [channelId], references: [id])
  type      SyncType
  status    SyncStatus
  message   String?
  createdAt DateTime   @default(now())
}

model OtaBooking {
  id            String        @id @default(cuid())
  hotelId       String
  hotel         Hotel         @relation(fields: [hotelId], references: [id])
  otaName       OtaName
  otaBookingRef String
  guestName     String
  guestEmail    String?
  guestPhone    String?
  roomId        String?
  room          Room?         @relation(fields: [roomId], references: [id])
  checkIn       DateTime
  checkOut      DateTime
  amount        Float
  commission    Float         @default(0)
  status        BookingStatus @default(CONFIRMED)
  rawData       Json?
  createdAt     DateTime      @default(now())
}

enum Role {
  SUPER_ADMIN
  HOTEL_OWNER
  STAFF
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum OtaName {
  BOOKING_COM
  MAKEMYTRIP
  GOOGLE_HOTEL_CENTRE
  EXPEDIA
  AGODA
}

enum SyncType {
  AVAILABILITY
  RATES
  BOOKING_PULL
  BOOKING_PUSH
}

enum SyncStatus {
  SUCCESS
  FAILED
  PENDING
}
model Payment {
  id              String        @id @default(cuid())
  bookingId       String?
  amount          Float
  currency        String        @default("INR")
  status          PaymentStatus @default(PENDING)
  orderId         String?
  razorpayId      String?
  guestName       String
  guestEmail      String
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}