generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(HOTEL_OWNER)
  createdAt DateTime @default(now())
  hotels    Hotel[]
}

model Hotel {
  id           String       @id @default(cuid())
  name         String
  address      String?
  phone        String?
  userId       String
  user         User         @relation(fields: [userId], references: [id])
  rooms        Room[]
  createdAt    DateTime     @default(now())
  channels     OtaChannel[]
  otaBookings  OtaBooking[]
  staffMembers Staff[]
  serviceCategories ServiceCategory[]
}

model Room {
  id                 String       @id @default(cuid())
  number             String
  type               String
  price              Float
  imageUrl           String?
  hotelId            String
  taxGroup           String?
  sacCode            String?
  defaultAdultStay   Int?         @default(1)
  defaultChildStay   Int?         @default(0)
  defaultInfantStay  Int?         @default(0)
  maxAdults          Int?         @default(2)
  maxChildren        Int?         @default(0)
  maxInfants         Int?         @default(0)
  extraAdultRate     Float?       @default(0)
  extraChildRate     Float?       @default(0)
  extraInfantRate    Float?       @default(0)
  hotel              Hotel        @relation(fields: [hotelId], references: [id])
  bookings           Booking[]
  ratePlans          RatePlan[]
  otaBookings        OtaBooking[]
  bookingRooms       BookingRoom[]
}

model Booking {
  id                 String        @id @default(cuid())
  roomId             String
  room               Room          @relation(fields: [roomId], references: [id])
  guestName          String
  guestEmail         String
  checkIn            DateTime
  checkOut           DateTime
  status             BookingStatus @default(PENDING)
  amount             Float
  notes              String?
  specialRequests    String?
  adults             Int?          @default(1)
  children           Int?          @default(0)
  infants            Int?          @default(0)
  source             String?       @default("WALK_IN")
  guestPhone         String?
  paymentMode        String?       @default("CASH")
  paymentAmount      Float?
  finalPaymentMode   String?
  finalPaymentAmount Float?
  createdAt          DateTime      @default(now())
  bookingRooms       BookingRoom[]
}

model BookingRoom {
  id              String   @id @default(cuid())
  bookingId       String
  roomId          String
  adults          Int      @default(1)
  children        Int      @default(0)
  infants         Int      @default(0)
  roomPrice       Float    @default(0)
  extraMattress   Int      @default(0)
  extraPillow     Int      @default(0)
  extraBedsheet   Int      @default(0)
  blanket         Int      @default(0)
  booking         Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  room            Room     @relation(fields: [roomId], references: [id])
  createdAt       DateTime @default(now())
}

model OtaChannel {
  id          String     @id @default(cuid())
  hotelId     String
  hotel       Hotel      @relation(fields: [hotelId], references: [id])
  name        OtaName
  isConnected Boolean    @default(false)
  apiKey      String?
  apiSecret   String?
  propertyId  String?
  lastSyncAt  DateTime?
  createdAt   DateTime   @default(now())
  syncLogs    SyncLog[]
  ratePlans   RatePlan[]

  @@unique([hotelId, name])
}

model RatePlan {
  id        String     @id @default(cuid())
  channelId String
  channel   OtaChannel @relation(fields: [channelId], references: [id])
  roomId    String
  room      Room       @relation(fields: [roomId], references: [id])
  date      DateTime
  price     Float
  available Int
  isBlocked Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model SyncLog {
  id        String     @id @default(cuid())
  channelId String
  channel   OtaChannel @relation(fields: [channelId], references: [id])
  type      SyncType
  status    SyncStatus
  message   String?
  createdAt DateTime   @default(now())
}

model OtaBooking {
  id            String        @id @default(cuid())
  hotelId       String
  hotel         Hotel         @relation(fields: [hotelId], references: [id])
  otaName       OtaName
  otaBookingRef String
  guestName     String
  guestEmail    String?
  guestPhone    String?
  roomId        String?
  room          Room?         @relation(fields: [roomId], references: [id])
  checkIn       DateTime
  checkOut      DateTime
  amount        Float
  commission    Float         @default(0)
  status        BookingStatus @default(CONFIRMED)
  rawData       Json?
  createdAt     DateTime      @default(now())
}

enum Role {
  SUPER_ADMIN
  HOTEL_OWNER
  STAFF
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  CHECKED_IN
  CHECKED_OUT
  UPGRADED
}

enum OtaName {
  BOOKING_COM
  MAKEMYTRIP
  GOOGLE_HOTEL_CENTRE
  EXPEDIA
  AGODA
}

enum SyncType {
  AVAILABILITY
  RATES
  BOOKING_PULL
  BOOKING_PUSH
}

enum SyncStatus {
  SUCCESS
  FAILED
  PENDING
}

model Payment {
  id              String        @id @default(cuid())
  bookingId       String?
  amount          Float
  currency        String        @default("INR")
  status          PaymentStatus @default(PENDING)
  orderId         String?
  razorpayId      String?
  guestName       String
  guestEmail      String
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model Staff {
  id         String       @id @default(cuid())
  employeeId String?
  name       String
  email      String       @unique
  password   String
  phone      String?
  role       String       @default("STAFF")
  hotelId    String
  hotel      Hotel        @relation(fields: [hotelId], references: [id])
  attendance Attendance[]
  createdAt  DateTime     @default(now())
}

model Attendance {
  id          String    @id @default(cuid())
  staffId     String
  staff       Staff     @relation(fields: [staffId], references: [id])
  date        DateTime  @default(now())
  checkIn     DateTime?
  checkOut    DateTime?
  totalHours  Float?
  status      String    @default("PRESENT")
  createdAt   DateTime  @default(now())
}

model OtpVerification {
  id        String   @id @default(cuid())
  email     String
  otp       String
  type      String   @default("PASSWORD_RESET")
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ServiceCategory {
  id          String        @id @default(cuid())
  hotelId     String
  hotel       Hotel         @relation(fields: [hotelId], references: [id])
  name        String
  serviceType ServiceType
  createdAt   DateTime      @default(now())
  items       ServiceItem[]
}

model ServiceItem {
  id           String          @id @default(cuid())
  categoryId   String
  category     ServiceCategory @relation(fields: [categoryId], references: [id])
  name         String
  itemCategory String
  price        Float           @default(0)
  minBaseline  Int             @default(0)
  stock        Int             @default(0)
  stockUpdated DateTime        @default(now())
  status       StockStatus     @default(NORMAL)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

enum ServiceType {
  FOOD
  DRINKS
  OTHER
}

enum StockStatus {
  NORMAL
  LOW
}